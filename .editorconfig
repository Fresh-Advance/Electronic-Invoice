# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines
[*]
end_of_line = lf
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# with a newline ending for every php file
[*.php]
insert_final_newline = true

# ident size 2 for yaml files
[{*.yml,*.yaml,*.json}]
indent_size = 2
